{
	"name": "reactive-notes-vue",
	"version": "1.0.0",
	"description": "Interactive Vue 3 components in Obsidian notes via vue-interactive code blocks.",
	"main": "main.js",
	"type": "module",
	"packageManager": "pnpm@9.15.9",
	"scripts": {
		"build:styles": "node scripts/build-styles.mjs",
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"sync-vault": "node scripts/sync-test-vault.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"license": "0-BSD",
	"dependencies": {
		"mathjax-full": "^3.2.2",
		"obsidian": "latest",
		"sucrase": "^3.35.1",
		"vue": "^3.5.13"
	},
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@tailwindcss/cli": "^4.3.0",
		"@types/mocha": "10.0.10",
		"@types/node": "^16.11.6",
		"@wdio/cli": "9.27.1",
		"@wdio/globals": "9.17.0",
		"@wdio/local-runner": "9.27.1",
		"@wdio/mocha-framework": "9.27.1",
		"@wdio/types": "9.16.2",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jsdom": "^26.0.0",
		"mocha": "10.8.2",
		"tailwindcss": "^4.3.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^3.0.5",
		"wdio-obsidian-reporter": "3.0.3",
		"wdio-obsidian-service": "3.0.3"
	}
}
